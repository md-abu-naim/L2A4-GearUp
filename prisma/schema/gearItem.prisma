model GearItem {
    id          String     @id @default(uuid())
    title       String
    description String?
    brand       String
    pricePerDay Int
    stock       Int?
    status      GearStatus @default(AVAILABLE)
    image       String?

    providerId String
    provider   User   @relation(fields: [providerId], references: [id])

    category String
    categoryies   Category @relation(fields: [category], references: [name])

    rentals RentalOrder[]
    reviews Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("gearItems")
}
