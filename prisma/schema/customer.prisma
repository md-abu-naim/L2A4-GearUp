model Customer {
    id           String     @id @default(uuid())
    name         String
    email        String     @unique
    role         UserRole   @default(CUSTOMER)
    staus        UserStatus @default(ACTIVE)
    phone        String?
    profileImage String?

    gearItems GearItem[]
    rentals   RentalOrder[]
    payments  Payment[]
    reviews   Review[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("customers")
}
